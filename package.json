{
  "name": "aya",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic terminal manager — Claude Code / Codex / shell sessions organized across projects.",
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n vite,tsc,electron -c green,blue,yellow \"npm:dev:renderer\" \"npm:dev:tsc\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:tsc": "tsc -w -p electron --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5183 dist-electron/main.js && cross-env AYA_DEV=1 electronmon .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron",
    "build": "npm run build:renderer && npm run build:electron",
    "test": "npm run build:electron && node --test \"tests/**/*.test.mjs\"",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@types/plist": "^3.0.5",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "plist": "^3.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.aya.app",
    "productName": "Aya",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  }
}
